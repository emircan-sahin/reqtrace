{
  "name": "reqtrace",
  "version": "0.1.7",
  "description": "Self-hosted HTTP request monitoring for Node.js — track outbound requests, proxy health, and failed targets in a realtime dashboard",
  "repository": {
    "type": "git",
    "url": "https://github.com/emircan-sahin/reqtrace.git",
    "directory": "packages/sdk"
  },
  "keywords": ["http", "monitoring", "proxy", "axios", "fetch", "websocket", "request-logger", "self-hosted"],
  "author": "Emircan Sahin",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json && tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "axios": ">=0.21.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "ws": "^8.19.0"
  }
}
